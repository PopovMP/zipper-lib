# Set default behavior to automatically normalize line endings
* text=auto

# Force LF line endings for all text files
*.ts           text eol=lf
*.js           text eol=lf
*.mjs          text eol=lf
*.json         text eol=lf
*.md           text eol=lf
*.txt          text eol=lf
.gitattributes text eol=lf
.gitignore     text eol=lf
